# MYBRON PWA Push Notifications Environment Variables
# Copy this file to .env.local for local development

# API Base URL (optional, defaults to production server)
# For local development with backend on localhost:
# VITE_API_URL=http://127.0.0.1:8000/api
# For production (default):
# VITE_API_URL=http://103.6.169.242/api

# Frontend VAPID Public Key (required for push subscription)
# This key is used by the browser to subscribe to push notifications
# Generate using: node scripts/generate-vapid-keys.mjs
VITE_VAPID_PUBLIC_KEY=

# Backend VAPID Private Key (server-side only, never expose to frontend)
# Used by backend to sign push notifications
VAPID_PRIVATE_KEY=

# VAPID Subject (email or URL identifying the application)
# Used for VAPID identification, typically a mailto: address
VAPID_SUBJECT=mailto:admin@mybron.uz

# Note: For production, these keys should be generated once and kept secure.
# The VAPID_PUBLIC_KEY should be exposed to the frontend via VITE_VAPID_PUBLIC_KEY.
# The VAPID_PRIVATE_KEY should only be accessible to the backend server.